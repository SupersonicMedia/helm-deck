---
const totalSlides = 17;
---

<nav id="deck-nav" class="fixed bottom-0 left-0 right-0 z-50">
  <div class="max-w-md mx-auto px-6 pb-4">
    <div class="bg-burgundy-dark/85 backdrop-blur-xl border border-white/10 rounded-full px-2 py-1.5 flex items-center justify-between shadow-2xl">
      <button id="deck-prev" class="w-9 h-9 rounded-full flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all active:scale-90" aria-label="Previous">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>

      <div class="flex-1 text-center min-w-0 px-1">
        <p class="text-white text-[10px] font-bold tracking-[0.2em] uppercase truncate" style="font-family: var(--font-body);"><span id="deck-label">HELM</span> <span id="deck-number" class="text-white/40 font-normal tracking-normal">1/17</span></p>
        <div class="flex justify-center gap-[3px] mt-1">
          {Array.from({ length: totalSlides }).map((_, i) => (
            <div class="deck-dot" data-index={i}></div>
          ))}
        </div>
      </div>

      <button id="deck-next" class="w-9 h-9 rounded-full flex items-center justify-center text-white/40 hover:text-white hover:bg-white/10 transition-all active:scale-90" aria-label="Next">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</nav>

<script>
  const deck = document.getElementById('deck');
  const slides = document.querySelectorAll('.deck-slide');
  const label = document.getElementById('deck-label');
  const numberEl = document.getElementById('deck-number');
  const dots = document.querySelectorAll('.deck-dot');
  const prevBtn = document.getElementById('deck-prev');
  const nextBtn = document.getElementById('deck-next');
  let currentIndex = 0;

  function updateNav(index) {
    currentIndex = index;
    const slide = slides[index];
    if (label && slide) {
      label.textContent = slide.dataset.label || '';
    }
    if (numberEl) {
      numberEl.textContent = (index + 1) + '/' + slides.length;
    }
    dots.forEach((dot, i) => {
      const el = dot as HTMLElement;
      if (i === index) {
        el.style.backgroundColor = '#E63946';
        el.style.width = '12px';
      } else {
        el.style.backgroundColor = 'rgba(255,255,255,0.2)';
        el.style.width = '5px';
      }
    });
  }

  // Detect which slide is in view via scroll position
  function detectSlide() {
    if (!deck) return;
    const scrollTop = deck.scrollTop;
    const slideHeight = deck.clientHeight;
    const index = Math.round(scrollTop / slideHeight);
    if (index !== currentIndex && index >= 0 && index < slides.length) {
      updateNav(index);
    }
  }

  deck?.addEventListener('scroll', () => {
    requestAnimationFrame(detectSlide);
  }, { passive: true });

  // Arrow navigation
  prevBtn?.addEventListener('click', () => {
    if (currentIndex > 0) {
      slides[currentIndex - 1]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  nextBtn?.addEventListener('click', () => {
    if (currentIndex < slides.length - 1) {
      slides[currentIndex + 1]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
      e.preventDefault();
      nextBtn?.click();
    } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
      e.preventDefault();
      prevBtn?.click();
    }
  });

  updateNav(0);
</script>

<style>
  .deck-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background-color: rgba(255,255,255,0.2);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
