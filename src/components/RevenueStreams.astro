---
const streams = [
  {
    num: '01',
    title: 'Event Bookings',
    description: '20% transaction fee on all hospitality services bookings\u2014our core revenue driver.',
    svg: '<svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" /></svg>',
  },
  {
    num: '02',
    title: 'Hospitality Subscription',
    description: 'Base tier at $20/month for marketplace listing. Premium tier at $40/month unlocks priority placement and enhanced tools.',
    svg: '<svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>',
  },
  {
    num: '03',
    title: 'AI Subscriptions',
    description: 'Tiered monthly subscriptions providing agentic planning and coordination tools for event organizers.',
    svg: '<svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>',
  },
];
---

<section class="py-28 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-3 fade-up">
      <img src="/images/helm-submark-burgundy.png" alt="HELM" class="h-8 w-auto mx-auto" />
    </div>
    <h2 class="section-heading text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-center mb-6 fade-up">
      Three Revenue Streams
    </h2>
    <div class="w-16 h-0.5 bg-gradient-to-r from-red to-burgundy mx-auto mb-14 fade-up"></div>

    <!-- Desktop grid -->
    <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8" data-stagger>
      {streams.map((stream) => (
        <div class="card-burgundy text-center fade-up relative overflow-hidden group">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-bright to-red opacity-50"></div>
          <div class="text-3xl font-bold mb-3 text-white/25" style="font-family: var(--font-heading);">{stream.num}</div>
          <h3 class="text-xl sm:text-2xl font-bold mb-4" style="font-family: var(--font-heading);">{stream.title}</h3>
          <p class="text-white/75 leading-relaxed mb-6 text-xs sm:text-sm" style="font-family: var(--font-body);">{stream.description}</p>
          <div class="text-white/40" set:html={stream.svg} />
        </div>
      ))}
    </div>

    <!-- Mobile swiper -->
    <div class="sm:hidden fade-up">
      <div class="swiper revenue-swiper">
        <div class="swiper-wrapper">
          {streams.map((stream) => (
            <div class="swiper-slide">
              <div class="card-burgundy text-center relative overflow-hidden mx-1">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-bright to-red opacity-50"></div>
                <div class="text-3xl font-bold mb-3 text-white/25" style="font-family: var(--font-heading);">{stream.num}</div>
                <h3 class="text-xl font-bold mb-4" style="font-family: var(--font-heading);">{stream.title}</h3>
                <p class="text-white/75 leading-relaxed mb-6 text-xs" style="font-family: var(--font-body);">{stream.description}</p>
                <div class="text-white/40" set:html={stream.svg} />
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination mt-6"></div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Swiper !== 'undefined') {
      new Swiper('.revenue-swiper', {
        slidesPerView: 1.1,
        spaceBetween: 8,
        centeredSlides: true,
        pagination: { el: '.revenue-swiper .swiper-pagination', clickable: true },
      });
    }
  });
</script>

<style>
  .revenue-swiper .swiper-pagination-bullet { background: var(--color-burgundy); opacity: 0.3; }
  .revenue-swiper .swiper-pagination-bullet-active { background: var(--color-red); opacity: 1; }
</style>
