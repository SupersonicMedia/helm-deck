<style>
  .market-chart-area {
    height: 120px;
  }
  @media (min-width: 768px) {
    .market-chart-area {
      height: 200px;
    }
  }
  .market-bar {
    height: 0px;
    transition: height 2.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .market-bar-label {
    opacity: 0;
    transition: opacity 0.5s ease 2s;
  }
  .market-bar.animate .market-bar-label {
    opacity: 1;
  }
</style>

<script is:inline>
  (function() {
    var bars = document.querySelectorAll('.market-bar');
    var slide = document.getElementById('slide-5');
    if (!slide || !bars.length) return;

    function getBarHeight(bar) {
      if (window.innerWidth >= 768 && bar.dataset.heightMd) {
        return bar.dataset.heightMd;
      }
      return bar.dataset.height;
    }

    function animateBars() {
      bars.forEach(function(bar) {
        bar.style.height = '0px';
        bar.classList.remove('animate');
      });
      setTimeout(function() {
        bars.forEach(function(bar) {
          bar.style.height = getBarHeight(bar) + 'px';
          bar.classList.add('animate');
        });
      }, 100);
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          animateBars();
        }
      });
    }, { threshold: 0.5 });

    observer.observe(slide);
  })();
</script>
