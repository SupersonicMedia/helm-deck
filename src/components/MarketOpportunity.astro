<style>
  .market-bar {
    height: 0px;
    transition: height 2.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .market-bar-label {
    opacity: 0;
    transition: opacity 0.5s ease 2s;
  }
  .market-bar.animate {
    /* height set by JS */
  }
  .market-bar.animate .market-bar-label {
    opacity: 1;
  }
</style>

<script is:inline>
  (function() {
    var bars = document.querySelectorAll('.market-bar');
    var slide = document.getElementById('slide-5');
    if (!slide || !bars.length) return;

    function animateBars() {
      // Reset
      bars.forEach(function(bar) {
        bar.style.height = '0px';
        bar.classList.remove('animate');
      });
      // Trigger grow after brief delay
      setTimeout(function() {
        bars.forEach(function(bar) {
          bar.style.height = bar.dataset.height + 'px';
          bar.classList.add('animate');
        });
      }, 100);
    }

    // Observe when slide comes into view
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          animateBars();
        }
      });
    }, { threshold: 0.5 });

    observer.observe(slide);

  })();
</script>
