---
const topPhotos = Array.from({ length: 6 }, (_, i) => `/images/thankyou-${i + 1}.jpg`);
const bottomPhotos = Array.from({ length: 6 }, (_, i) => `/images/thankyou-${i + 7}.jpg`);
---

<section class="px-5 h-full flex flex-col items-center justify-center pb-14">
  <div class="max-w-5xl mx-auto w-full">
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-1.5 sm:gap-2 mb-4">
      {topPhotos.map((src) => (
        <img src={src} alt="HELM hospitality" class="w-full aspect-square object-cover rounded-lg shadow-md" loading="lazy" />
      ))}
    </div>

    <div class="text-center py-3 sm:py-6 relative">
      <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none">
        <img src="/images/helm-submark-burgundy.png" alt="" class="h-40 sm:h-64 w-auto" />
      </div>
      <h2 class="section-heading text-4xl sm:text-6xl md:text-7xl relative z-10">Thank You</h2>
      <div class="w-16 h-0.5 bg-gradient-to-r from-red to-burgundy mx-auto mt-3 rounded-full"></div>
    </div>

    <div class="grid grid-cols-3 sm:grid-cols-6 gap-1.5 sm:gap-2 mt-4">
      {bottomPhotos.map((src) => (
        <img src={src} alt="HELM hospitality" class="w-full aspect-square object-cover rounded-lg shadow-md" loading="lazy" />
      ))}
    </div>
  </div>
</section>
