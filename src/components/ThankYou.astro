---
const allPhotos = Array.from({ length: 12 }, (_, i) => `/images/thankyou-${i + 1}.jpg`);
const topPhotos = allPhotos.slice(0, 6);
const bottomPhotos = allPhotos.slice(6);
---

<section class="py-28 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Top row: grid on desktop, swiper on mobile -->
    <div class="hidden sm:grid sm:grid-cols-3 md:grid-cols-6 gap-3 mb-8 sm:mb-12 fade-up" data-stagger>
      {topPhotos.map((src) => (
        <img src={src} alt="HELM hospitality" class="w-full aspect-square object-cover rounded-xl shadow-md hover:scale-105 hover:shadow-xl transition-all duration-400 fade-up" loading="lazy" />
      ))}
    </div>

    <div class="sm:hidden mb-8 fade-up">
      <div class="swiper thankyou-top-swiper">
        <div class="swiper-wrapper">
          {topPhotos.map((src) => (
            <div class="swiper-slide" style="width: auto;">
              <img src={src} alt="HELM hospitality" class="w-32 h-32 object-cover rounded-xl shadow-md" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Thank You text -->
    <div class="text-center py-8 sm:py-12 fade-up relative">
      <div class="absolute inset-0 flex items-center justify-center opacity-[0.04] pointer-events-none">
        <img src="/images/helm-submark-burgundy.png" alt="" class="h-52 sm:h-80 w-auto" />
      </div>
      <h2 class="section-heading text-5xl sm:text-6xl md:text-8xl relative z-10">
        Thank You
      </h2>
      <div class="w-20 h-1 bg-gradient-to-r from-red to-burgundy mx-auto mt-6 rounded-full"></div>
    </div>

    <!-- Bottom row: grid on desktop, swiper on mobile -->
    <div class="hidden sm:grid sm:grid-cols-3 md:grid-cols-6 gap-3 mt-8 sm:mt-12 fade-up" data-stagger>
      {bottomPhotos.map((src) => (
        <img src={src} alt="HELM hospitality" class="w-full aspect-square object-cover rounded-xl shadow-md hover:scale-105 hover:shadow-xl transition-all duration-400 fade-up" loading="lazy" />
      ))}
    </div>

    <div class="sm:hidden mt-8 fade-up">
      <div class="swiper thankyou-bottom-swiper">
        <div class="swiper-wrapper">
          {bottomPhotos.map((src) => (
            <div class="swiper-slide" style="width: auto;">
              <img src={src} alt="HELM hospitality" class="w-32 h-32 object-cover rounded-xl shadow-md" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Swiper !== 'undefined') {
      const opts = { slidesPerView: 'auto', spaceBetween: 10, freeMode: true };
      new Swiper('.thankyou-top-swiper', opts);
      new Swiper('.thankyou-bottom-swiper', opts);
    }
  });
</script>
