<section class="py-20 sm:py-28 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <!-- Image with glass frame -->
    <div class="fade-left">
      <div class="relative">
        <img
          src="/images/challenge.jpg"
          alt="Event planner working on laptop surrounded by scattered papers"
          class="rounded-2xl shadow-2xl w-full object-cover aspect-[4/5]"
          loading="lazy"
        />
        <!-- Red accent corner -->
        <div class="absolute -bottom-3 -right-3 w-24 h-24 rounded-2xl bg-gradient-to-br from-red/20 to-burgundy/20 backdrop-blur-sm border border-red/10 -z-10"></div>
        <!-- Glass overlay tag -->
        <div class="absolute bottom-6 left-6 glass px-4 py-2 flex items-center gap-2">
          <span class="red-dot"></span>
          <span class="text-sm font-semibold text-charcoal" style="font-family: var(--font-body);">The Problem</span>
        </div>
