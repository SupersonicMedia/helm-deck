<style>
  .funds-animate, .funds-row {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0s);
  }
  .funds-animate.visible, .funds-row.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (function() {
    var slide = document.getElementById('slide-14');
    if (!slide) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var els = slide.querySelectorAll('.funds-animate, .funds-row');
        if (entry.isIntersecting) {
          els.forEach(function(el) { el.classList.add('visible'); });
        } else {
          els.forEach(function(el) { el.classList.remove('visible'); });
        }
      });
    }, { threshold: 0.3 });

    observer.observe(slide);
  })();
</script>
