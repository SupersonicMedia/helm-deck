---
const features = [
  { title: 'Curated Marketplace', description: 'Vetted chefs, servers, bartenders, venues and entertainment professionals\u2014all verified and ready to deliver excellence.', image: '/images/feature-marketplace.png' },
  { title: 'Agentic AI Planner', description: 'Intelligent automation that sources optimal vendors, builds timelines, recommends quantities, coordinates options, and manages confirmations\u2014not just a chatbot.', image: '/images/feature-planner.png' },
  { title: 'Execution Layer', description: 'Seamless booking, messaging, transactions, reviews, and accountability\u2014all in one premium platform with consistent outcomes.', image: '/images/feature-execution.png' },
];
---

<section class="px-5 h-full flex flex-col justify-center pb-14">
  <div class="max-w-7xl mx-auto text-center w-full">
    <div class="mb-1">
      <img src="/images/helm-submark-burgundy.png" alt="HELM" class="h-5 sm:h-7 w-auto mx-auto" />
    </div>
    <h2 class="section-heading text-2xl sm:text-4xl mb-1">AI-Powered Event Excellence</h2>
    <div class="w-10 h-0.5 bg-gradient-to-r from-red to-burgundy mx-auto mb-4 sm:mb-6"></div>

    <!-- Desktop grid -->
    <div class="hidden md:grid md:grid-cols-3 gap-4 mb-4">
      {features.map((f) => (
        <div class="group glass-strong overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-1">
          <div class="h-40 overflow-hidden">
            <img src={f.image} alt={f.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-4">
            <h3 class="text-sm font-bold text-burgundy mb-1" style="font-family: var(--font-heading);">{f.title}</h3>
            <p class="text-charcoal/70 text-xs leading-snug" style="font-family: var(--font-body);">{f.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile swiper -->
    <div class="md:hidden mb-3">
      <div class="swiper features-swiper">
        <div class="swiper-wrapper">
          {features.map((f) => (
            <div class="swiper-slide">
              <div class="glass-strong overflow-hidden text-left">
                <div class="h-40 overflow-hidden">
                  <img src={f.image} alt={f.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-bold text-burgundy mb-1" style="font-family: var(--font-heading);">{f.title}</h3>
                  <p class="text-charcoal/70 text-[11px] leading-snug" style="font-family: var(--font-body);">{f.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-1.5 mt-3">
          {features.map((_, i) => (
            <div class="features-dot w-1.5 h-1.5 rounded-full bg-burgundy/20" data-index={i}></div>
          ))}
        </div>
      </div>
    </div>

    <p class="text-[10px] sm:text-xs italic text-charcoal/50 leading-snug max-w-xl mx-auto" style="font-family: var(--font-body);">
      The AI planner will first source vendors directly from HELM&rsquo;s curated marketplace. For larger or more complex events, it will also reference a growing dataset of hospitality operations and past event outcomes to optimize planning.
    </p>
  </div>
</section>

<script is:inline>
  function initFeaturesSwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initFeaturesSwiper, 100);
      return;
    }
    new Swiper('.features-swiper', {
      slidesPerView: 1, spaceBetween: 12,
      on: { slideChange: function() {
        document.querySelectorAll('.features-dot').forEach(function(d, i) {
          if (i === this.activeIndex) { d.style.background = '#C41E3A'; d.style.width = '12px'; }
          else { d.style.background = 'rgba(91,26,42,0.2)'; d.style.width = '6px'; }
        }.bind(this));
      }}
    });
    var first = document.querySelector('.features-dot[data-index="0"]');
    if (first) { first.style.background = '#C41E3A'; first.style.width = '12px'; }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFeaturesSwiper);
  } else {
    initFeaturesSwiper();
  }
</script>
<style>.features-dot { transition: all 0.3s ease; }</style>
