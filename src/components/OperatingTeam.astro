<script is:inline>
  function initTeamSwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initTeamSwiper, 100);
      return;
    }
    new Swiper('.team-swiper', {
      slidesPerView: 1, spaceBetween: 12,
      on: { slideChange: function() {
        document.querySelectorAll('.team-dot').forEach(function(d, i) {
          if (i === this.activeIndex) { d.style.background = '#C41E3A'; d.style.width = '12px'; }
          else { d.style.background = 'rgba(91,26,42,0.2)'; d.style.width = '6px'; }
        }.bind(this));
      }}
    });
    var first = document.querySelector('.team-dot[data-index="0"]');
    if (first) { first.style.background = '#C41E3A'; first.style.width = '12px'; }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTeamSwiper);
  } else {
    initTeamSwiper();
  }
</script>
<style>.team-dot { transition: all 0.3s ease; }</style>
