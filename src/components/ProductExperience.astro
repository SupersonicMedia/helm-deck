<section class="px-5 h-full flex flex-col justify-center pb-14">
  <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-3 md:gap-12 items-center">
    <div class="order-2 md:order-1">
      <p class="section-label mb-1 text-[10px]">Product Experience</p>
      <h2 class="section-heading fade-up text-2xl sm:text-4xl mb-2">From Idea to Booked Event in Minutes</h2>
      <p class="text-[11px] sm:text-sm mb-1.5" style="font-family: var(--font-body);">A corporate client simply types:</p>
      <div class="glass-strong p-2.5 sm:p-3 mb-2 sm:mb-3 flex items-center gap-2">
        <img src="/images/sparkle.png" alt="" class="w-4 h-4 flex-shrink-0" />
        <p class="text-[11px] sm:text-sm flex-1" style="font-family: var(--font-body);">Plan a 100-person cocktail reception in NYC next month. Budget $35k.</p>
        <div class="w-7 h-7 rounded-full bg-gradient-to-br from-red to-burgundy flex items-center justify-center flex-shrink-0">
          <span class="text-white text-xs">&#8593;</span>
        </div>
      </div>
      <p class="text-[10px] sm:text-xs leading-relaxed text-charcoal/60 mb-2 sm:mb-3" style="font-family: var(--font-body);">
        Within minutes, HELM&rsquo;s AI outputs venue and vendor options with availability, a complete staffing plan with roles and schedules, a detailed timeline and run-of-show, plus alcohol and food quantity guidance. The client books in-app, and AI manages all confirmations and changes.
      </p>
      <div class="glass-dark p-2.5 sm:p-3 flex items-center gap-2">
        <img src="/favicon.png" alt="HELM" class="w-6 h-6 sm:w-8 sm:h-8 flex-shrink-0 rounded-lg" />
        <p class="text-[10px] sm:text-[11px] italic text-charcoal/70" style="font-family: var(--font-body);">The mobile application will be accessible on iOS and Android platforms, in addition to a web-based version.</p>
      </div>
    </div>
    <div class="flex justify-center order-1 md:order-2">
      <div class="relative max-w-[140px] sm:max-w-[180px] md:max-w-[280px] cursor-pointer" id="phone-trigger">
        <div class="absolute inset-0 bg-gradient-to-br from-red/10 via-burgundy/5 to-transparent rounded-[3rem] blur-2xl scale-110"></div>
        <img src="/images/phone-mockup.png" alt="HELM mobile app" class="w-full max-h-[35vh] sm:max-h-none object-contain relative z-10 drop-shadow-2xl scale-in" loading="lazy" />
        <p class="text-[10px] text-charcoal/40 text-center mt-1 relative z-10 md:hidden" style="font-family: var(--font-body);">Tap to expand</p>
      </div>
    </div>

    <!-- Fullscreen lightbox -->
    <div id="phone-lightbox" class="fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm items-center justify-center hidden" style="display:none;">
      <button id="phone-lightbox-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 text-white flex items-center justify-center text-xl hover:bg-white/20 transition-colors">&times;</button>
      <img src="/images/phone-mockup.png" alt="HELM mobile app" class="max-h-[85vh] max-w-[90vw] object-contain drop-shadow-2xl" />
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var trigger = document.getElementById('phone-trigger');
    var lightbox = document.getElementById('phone-lightbox');
    var closeBtn = document.getElementById('phone-lightbox-close');
    if (trigger && lightbox) {
      trigger.addEventListener('click', function() {
        lightbox.style.display = 'flex';
      });
      closeBtn.addEventListener('click', function() {
        lightbox.style.display = 'none';
      });
      lightbox.addEventListener('click', function(e) {
        if (e.target === lightbox) lightbox.style.display = 'none';
      });
    }
  })();
</script>
