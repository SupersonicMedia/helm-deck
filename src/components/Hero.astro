---
const heroImages = Array.from({ length: 9 }, (_, i) => `/images/hero-${i + 1}.jpg`);
---

<section class="px-5 h-full flex flex-col items-center justify-center gap-6 pb-12">
  <img src="/images/helm-logo-burgundy.png" alt="HELM" class="w-full max-w-[90vw] sm:max-w-md md:max-w-lg lg:max-w-xl h-auto" />

  <div class="flex flex-col items-center gap-4">
    <div class="flex flex-col items-center gap-1.5">
      <span class="pill text-xs sm:text-sm px-6 py-2 whitespace-nowrap">Luxury Hospitality Marketplace</span>
      <span class="text-burgundy text-sm font-light">+</span>
      <span class="pill-red text-xs sm:text-sm px-6 py-2 whitespace-nowrap">Agentic AI Event Planner</span>
    </div>

    <p class="text-center text-xs sm:text-base md:text-lg text-charcoal/70 leading-relaxed" style="font-family: var(--font-body);">
      Book premium event talent and services like Airbnb. Our AI agent plans, coordinates, and executes the entire workflow.
    </p>
  </div>

  <div class="w-screen overflow-hidden -mx-5">
    <div class="hero-marquee flex gap-3">
      {[...heroImages, ...heroImages].map((src) => (
        <img src={src} alt="HELM hospitality" loading="lazy" class="w-28 h-28 sm:w-40 sm:h-40 md:w-48 md:h-48 object-cover rounded-xl shadow-lg flex-shrink-0" />
      ))}
    </div>
  </div>
</section>

<style>
  .hero-marquee {
    animation: marquee 25s linear infinite;
    width: max-content;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
