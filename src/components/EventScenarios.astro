---
const events = [
  {
    num: 'Event 01', title: 'Luxury Private Dinner', guests: '20 guests',
    staffing: ['Chef: $3,000', '2 Servers: $800', '1 Bartender: $500'],
    gmv: '$4,300', revenue: '$860',
  },
  {
    num: 'Event 02', title: 'Corporate Retreat', guests: '75 guests',
    staffing: ['Chef: $11,250', 'Sous: $5,625', '7 Servers: $2,800', '2 Bartenders: $1,000', 'Entertainment: $1,500'],
    gmv: '$22,175', revenue: '$4,435',
  },
  {
    num: 'Event 03', title: 'Large Corporate Event', guests: '150 guests',
    staffing: [],
    description: 'Premium staffing across all service categories with enhanced entertainment and sommelier services.',
    gmv: '$42,250', revenue: '$8,450',
  },
];

function renderCard(event: typeof events[0]) {
  return event;
}
---

<section class="py-28 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-2 fade-up">
      <p class="section-label">Unit Economics</p>
    </div>
    <h2 class="section-heading text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-center mb-6 fade-up">
      Real Event Scenarios
    </h2>
    <div class="w-16 h-0.5 bg-gradient-to-r from-red to-burgundy mx-auto mb-14 fade-up"></div>

    <!-- Desktop grid -->
    <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 mb-8" data-stagger>
      {events.map((event) => (
        <div class="card-burgundy flex flex-col fade-up relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-bright to-red opacity-60"></div>
          <p class="text-white/40 text-xs mb-1" style="font-family: var(--font-body);">{event.num}</p>
          <h3 class="text-lg sm:text-xl font-bold mb-3" style="font-family: var(--font-heading);">{event.title}</h3>
          <p class="text-white/70 mb-4 text-sm" style="font-family: var(--font-body);">&#128101; {event.guests}</p>
          {event.staffing.length > 0 ? (
            <div class="space-y-1.5 mb-6 flex-1">
              {event.staffing.map((item) => (<p class="text-white/75 text-xs" style="font-family: var(--font-body);">{item}</p>))}
            </div>
          ) : (
            <p class="text-white/75 text-xs mb-6 flex-1" style="font-family: var(--font-body);">{event.description}</p>
          )}
          <div class="border-t border-white/15 pt-4 mt-auto">
            <p class="text-center font-bold text-base" style="font-family: var(--font-body);">GMV: <span class="text-lg">{event.gmv}</span></p>
            <p class="text-center text-white/70 text-sm" style="font-family: var(--font-body);">HELM Revenue: <strong>{event.revenue}</strong></p>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile swiper -->
    <div class="sm:hidden mb-8 fade-up">
      <div class="swiper events-swiper">
        <div class="swiper-wrapper">
          {events.map((event) => (
            <div class="swiper-slide">
              <div class="card-burgundy flex flex-col relative overflow-hidden mx-1 min-h-[320px]">
                <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-bright to-red opacity-60"></div>
                <p class="text-white/40 text-xs mb-1" style="font-family: var(--font-body);">{event.num}</p>
                <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-heading);">{event.title}</h3>
                <p class="text-white/70 mb-4 text-sm" style="font-family: var(--font-body);">&#128101; {event.guests}</p>
                {event.staffing.length > 0 ? (
                  <div class="space-y-1.5 mb-6 flex-1">
                    {event.staffing.map((item) => (<p class="text-white/75 text-xs" style="font-family: var(--font-body);">{item}</p>))}
                  </div>
                ) : (
                  <p class="text-white/75 text-xs mb-6 flex-1" style="font-family: var(--font-body);">{event.description}</p>
                )}
                <div class="border-t border-white/15 pt-4 mt-auto">
                  <p class="text-center font-bold text-base" style="font-family: var(--font-body);">GMV: {event.gmv}</p>
                  <p class="text-center text-white/70 text-sm" style="font-family: var(--font-body);">HELM Revenue: <strong>{event.revenue}</strong></p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination mt-6"></div>
      </div>
    </div>

    <p class="text-center text-xs italic text-charcoal/50 fade-up px-4" style="font-family: var(--font-body);">
      Pricing anchors: Chefs $100&ndash;$200/guest, Sous +$50&ndash;$100/guest, Servers $400, Bartenders/Sommeliers $500, Entertainment $500&ndash;$5,000.
    </p>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Swiper !== 'undefined') {
      new Swiper('.events-swiper', {
        slidesPerView: 1.1,
        spaceBetween: 8,
        centeredSlides: true,
        pagination: { el: '.events-swiper .swiper-pagination', clickable: true },
      });
    }
  });
</script>

<style>
  .events-swiper .swiper-pagination-bullet { background: var(--color-burgundy); opacity: 0.3; }
  .events-swiper .swiper-pagination-bullet-active { background: var(--color-red); opacity: 1; }
</style>
