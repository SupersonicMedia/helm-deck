<script is:inline>
  function initEventsSwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initEventsSwiper, 100);
      return;
    }
    new Swiper('.events-swiper', {
      slidesPerView: 1, spaceBetween: 12,
      on: { slideChange: function() {
        document.querySelectorAll('.events-dot').forEach(function(d, i) {
          if (i === this.activeIndex) { d.style.background = '#C41E3A'; d.style.width = '12px'; }
          else { d.style.background = 'rgba(91,26,42,0.2)'; d.style.width = '6px'; }
        }.bind(this));
      }}
    });
    var first = document.querySelector('.events-dot[data-index="0"]');
    if (first) { first.style.background = '#C41E3A'; first.style.width = '12px'; }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEventsSwiper);
  } else {
    initEventsSwiper();
  }
</script>
<style>.events-dot { transition: all 0.3s ease; }</style>
